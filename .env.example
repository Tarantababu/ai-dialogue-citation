# ──────────────────────────────────────────────────────────────────────────
#  SIFIR DÜŞÜŞ PROTOCOL — Environment Template
#  Copy this file to `.env.local` and fill in the values.
#  NEVER commit `.env.local`. Variables WITHOUT the NEXT_PUBLIC_ prefix are
#  server-only and are never shipped to the browser bundle.
# ──────────────────────────────────────────────────────────────────────────

# ── Blockchain (Polygon) ───────────────────────────────────────────────────
# Public RPC endpoint for the Polygon network the contract is deployed on.
# Polygon Amoy testnet example: https://rpc-amoy.polygon.technology
# Polygon mainnet example:      https://polygon-rpc.com
NEXT_PUBLIC_POLYGON_RPC_URL="https://rpc-amoy.polygon.technology"

# Deployed CitationRegistry.sol contract address (0x...)
NEXT_PUBLIC_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# Chain id: 137 = Polygon mainnet, 80002 = Polygon Amoy testnet
NEXT_PUBLIC_CHAIN_ID="80002"

# ── Custodial signer (SERVER-ONLY) ─────────────────────────────────────────
# Private key of the DeCite relayer wallet that notarizes every citation and
# pays the gas. Users never connect their own wallet. Keep this FUNDED with a
# little POL/MATIC. NEVER expose it (no NEXT_PUBLIC_ prefix) and NEVER commit it.
RELAYER_PRIVATE_KEY="0xYOUR_RELAYER_PRIVATE_KEY"

# ── Pinata / IPFS ──────────────────────────────────────────────────────────
# SERVER-ONLY secret. Used by Server Actions to pin payloads. Do NOT expose.
PINATA_JWT="YOUR_PINATA_JWT"

# Public dedicated gateway hostname (no protocol), e.g. your-name.mypinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY="gateway.pinata.cloud"
